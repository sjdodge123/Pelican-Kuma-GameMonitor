# Config for pelican_reboot.py — copy to /etc/pelican-reboot.env and chmod 600
# (it holds API keys). Same two keys PuK uses; the client key must belong to an
# admin user so it can control every server.
PEL_URL=https://panel.example.com
PEL_APP_KEY=ptla_xxxxxxxxxxxxxxxx
PEL_CLIENT_KEY=ptlc_xxxxxxxxxxxxxxxx
#PEL_SSL_VERIFY=1

# --- RAM-triggered reboot (pelican-ramwatch.timer) ---
# Reboot when MemAvailable stays below this for RAM_BREACH_COUNT consecutive
# checks (timer fires every 5 min => default = ~15 min sustained pressure).
#RAM_MIN_AVAILABLE_MB=1024
#RAM_BREACH_COUNT=3
# Never auto-reboot more often than this. If the cooldown keeps being hit, the
# host genuinely needs more RAM — a reboot loop would just churn players.
#REBOOT_COOLDOWN_HOURS=12

# --- Player warnings (sent to each running server's console before the stop) ---
# Countdown marks in seconds; empty disables. {msg}/{seconds} are substituted.
#NOTICE_SCHEDULE=90,30,10
#NOTICE_COMMAND=say {msg}
#NOTICE_MESSAGE=SERVER REBOOTING for maintenance in {seconds} seconds! It will be back in a few minutes.

# --- PuK maintenance block (suppresses Discord pings for the planned outage) ---
# The /api/suppress endpoint of the PuK admin UI, plus its basic-auth creds.
#PUK_SUPPRESS_URL=https://status.example.net/admin/api/suppress
#PUK_ADMIN_USER=admin
#PUK_ADMIN_PASS=
#SUPPRESS_MINUTES=30

# --- Timing ---
# Seconds to wait for servers to stop cleanly before sending kill.
#STOP_TIMEOUT=300
# Seconds between server starts after boot (avoids a RAM/CPU spike).
#START_STAGGER=20
# Seconds to wait for the panel to come back after boot.
#PANEL_WAIT_TIMEOUT=600
