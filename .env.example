# -------------------
# Uptime Kuma settings
# -------------------
KUMA_URL=http://<INSERT IP HERE>:<INSERT PORT HERE>
KUMA_USER=<INSERT USER>
KUMA_PASS=<INSERT PASS>
KUMA_SSL_VERIFY=1

# Naming / cleanup
KUMA_NAME_PREFIX=AUTO
KUMA_INTERVAL=60
KUMA_STALE_DAYS=7

# -------------------
# Pelican panel settings
# -------------------
PEL_URL=http://<INSERT IP HERE>:<INSERT PORT HERE>
PEL_APP_KEY=<INSERT APP KEY HERE>
PEL_CLIENT_KEY=<INSERT CLIENT KEY HERE>
PEL_SSL_VERIFY=1

# Cache
CACHE_PATH=/data/pelican_servers_cache.json
CACHE_TTL_SECONDS=300

# -------------------
# Branding (GamerSaloon)
# These are the DEFAULTS; they can also be edited live in the admin UI (saved to
# /data/branding.json, which takes precedence over these env vars).
# Code defaults are neutral ("GameMonitor"); this deployment sets GamerSaloon.
#
# Assets are self-hosted by this container from app/static/brand/. The logo/avatar
# below are ROOT-RELATIVE paths; set BRAND_ASSET_BASE_URL to the container's
# externally-reachable base so Discord + the Kuma status page get an absolute URL.
# (Discord must reach it from the internet; the status-page logo only needs to be
# reachable by whoever views the status page.) You can also just paste full
# https://... URLs into BRAND_LOGO_URL / BRAND_AVATAR_URL instead.
# -------------------
BRAND_NAME=GamerSaloon
BRAND_ASSET_BASE_URL=<e.g. https://monitor.gamersaloon.example>
BRAND_LOGO_URL=/static/brand/logo.png
BRAND_AVATAR_URL=/static/brand/avatar.png
BRAND_WEBHOOK_USERNAME=GamerSaloon
BRAND_COLOR=#c79a3b
BRAND_URL=

# -------------------
# Discord webhooks
# Per-server webhooks are managed in the admin UI and stored in /data/webhooks.json.
# DISCORD_WEBHOOK_URL is the optional global fallback for servers without their own.
# -------------------
DISCORD_WEBHOOK_URL=
DISCORD_STATE_PATH=/data/discord_state.json
# A status change must hold for this many consecutive runs (~minutes) before a
# Discord notification fires. Debounces transient up/down flaps. Set to 1 for the
# old behavior (notify on every change).
DISCORD_CONFIRM_RUNS=2
# By default each Discord webhook's own name + avatar (set in Discord's webhook
# UI) identify the message. Set to 1 to override every message with the brand
# username/avatar instead.
DISCORD_USE_BRAND_IDENTITY=0
# Public URL of the live status page. When set, a "View live status" link is
# appended to notifications. A bare host is upgraded to https://.
STATUS_PAGE_PUBLIC_URL=

# -------------------
# Admin web UI
# Setting ADMIN_PASS turns on HTTP basic auth (strongly recommended). ADMIN_USER
# defaults to "admin" if left blank. Auth is OFF only when ADMIN_PASS is empty.
# ADMIN_URL_PREFIX serves the UI under a sub-path so it can share the status
# domain (e.g. status.example.net/admin) instead of needing its own subdomain;
# the reverse proxy forwards /admin/... unchanged. ADMIN_PUBLIC_URL is where the
# UI is reachable, and is linked from the status-page footer.
# -------------------
ADMIN_PORT=8080
ADMIN_USER=admin
ADMIN_PASS=
ADMIN_SECRET_KEY=change-me
ADMIN_URL_PREFIX=
ADMIN_PUBLIC_URL=

# -------------------
# Dynamic status page (single page, grouped by wing/node)
# The status page is PUBLIC in Kuma by default (the branding is meant to be seen);
# enable password protection in the Kuma status-page editor if you want it private.
# STATUS_PAGE_ICON: a local /static/... path is embedded as a base64 data URI so the
# logo shows on the status page with NO hosting needed; an absolute URL is used as-is.
# -------------------
STATUS_PAGE_ENABLED=1
STATUS_PAGE_SLUG=gamersaloon
STATUS_PAGE_TITLE=
STATUS_PAGE_THEME=dark
STATUS_PAGE_UNGROUPED_LABEL=Other
STATUS_PAGE_ICON=/static/brand/icon.png

# -------------------
# Maintenance sync (opt-in): mirror each server's Pelican power schedules into
# Kuma maintenance windows, so a server that's off during its scheduled hours
# shows "maintenance" (not "degraded") and isn't counted against uptime.
# Requires the Client API key to be able to read schedules.
# SCHEDULE_TZ must match the timezone your Pelican panel evaluates crons in
# (UTC by default). Maintenance windows are created in that same timezone.
# -------------------
MAINTENANCE_SYNC_ENABLED=0
SCHEDULE_TZ=UTC
SCHEDULE_CACHE_TTL_SECONDS=3600
MAINTENANCE_STATE_PATH=/data/maintenance_state.json
SCHEDULE_CACHE_PATH=/data/pelican_schedules_cache.json
