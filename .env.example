# Uptime Kuma (must be reachable from this container)
KUMA_URL=http://<KUMA_URL>:3001
KUMA_USER=<KUMA_USER>
KUMA_PASS=<KUMA_PASS>
KUMA_SSL_VERIFY=1

# Pelican panel (can be localhost on the node)
PEL_URL=http://<PELICAN_PANEL_IP>
PEL_KEY=<PELICAN_PANEL_API_KEY>
PEL_API_MODE=application
PEL_SSL_VERIFY=1

# Naming + behavior
KUMA_NAME_PREFIX=AUTO
KUMA_INTERVAL=60
KUMA_STALE_DAYS=7
DISCOVER_UUID_ONLY=1
NAME_INCLUDE_PORTS=0
CHECK_PAL_PROC=1